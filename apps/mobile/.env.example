# Copie para .env e preencha com seus valores reais antes de rodar localmente

# URL da API (quando rodar local: http://localhost:3001/api)
# Quando a API estiver no Render, use a URL do Render:
# EXPO_PUBLIC_API_URL="https://visitas-leiteiras-api.onrender.com/api"
EXPO_PUBLIC_API_URL="http://localhost:3001/api"

# Dados do projeto na Expo (necessarios para EAS Update / EAS Build)
# Obtenha em: https://expo.dev -> seu projeto -> Project ID
EXPO_OWNER="seu-usuario-na-expo"
EXPO_PROJECT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
