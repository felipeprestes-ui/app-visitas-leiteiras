# === Banco de dados ===
# Em producao (Render/Railway), esta variavel e configurada automaticamente.
# Para desenvolvimento local: copie este arquivo para .env e ajuste.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visitas_leiteiras?schema=public"

# === Autenticacao JWT ===
# Em producao, o render.yaml gera valores aleatorios automaticamente.
# Para desenvolvimento local, qualquer string serve.
JWT_ACCESS_SECRET="dev-access-secret-troque-em-producao"
JWT_REFRESH_SECRET="dev-refresh-secret-troque-em-producao"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="30"

# === Porta ===
# Render e Railway injetam PORT automaticamente. Nao defina em producao.
# Para dev local: 3001
PORT="3001"

# === Ambiente ===
NODE_ENV="development"
