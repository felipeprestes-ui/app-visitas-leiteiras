# Variaveis de ambiente - App Visitas Leiteiras Backend

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# JWT
JWT_SECRET="sua-chave-secreta-super-segura-aqui"
JWT_EXPIRES_IN="30d"

# Servidor
PORT=3000

# CORS - origens permitidas (* para todos, ou URL especifica do app)
CORS_ORIGIN="*"

# Setup inicial - segredo para criar usuarios via POST /auth/setup (sem autenticacao)
# Configure no painel do Render antes de chamar /auth/setup pela primeira vez
SETUP_SECRET="troque-por-uma-senha-forte-aqui"
